{
  "name": "@tripplan/api",
  "version": "0.0.0",
  "private": true,
  "description": "HTTP API for TripPlan (Effect + Lambda)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "openapi": "node -e \"const fs=require('fs'); if(!fs.existsSync('openapi.yaml')) process.exit(1); console.log('OpenAPI source of truth: openapi.yaml');\""
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1085.0",
    "@aws-sdk/lib-dynamodb": "^3.1085.0",
    "@ericminassian/auth": "^1.1.0",
    "@tripplan/domain": "workspace:*",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@tripplan/eslint-config": "workspace:*",
    "@tripplan/tsconfig": "workspace:*",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "typescript": "~5.7.3",
    "vitest": "^4.1.10"
  }
}
