{
  "name": "@tripplan/e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright end-to-end tests for TripPlan",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:share": "playwright test tests/share-session.spec.ts",
    "test:critical": "playwright test tests/critical-path.spec.ts",
    "playwright:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@tripplan/eslint-config": "workspace:*",
    "@tripplan/tsconfig": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "typescript": "~5.7.3",
    "vitest": "^4.1.10"
  }
}
