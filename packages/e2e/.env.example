# Optional local file: copy to packages/e2e/.env (gitignored).
# loadE2EEnv() loads .env when present; it does NOT override already-exported vars.
# You can also: set -a && source .env && set +a

# Public plan host (SPA + /api on same origin — required for first-party share cookies).
# Optional: defaults to https://plan-staging.ericminassian.com when unset.
E2E_BASE_URL=https://plan-staging.ericminassian.com

# --- Option A (share smoke only): pre-seeded share capability token ---
# Create once as an owner: Share panel → copy link → take the hash fragment after `#`.
# No passkeys at test time. Grant should remain unrevoked and unexpired.
E2E_SHARE_TOKEN=
# Optional but recommended: title shown in the share viewer for assertion.
E2E_SHARE_TRIP_TITLE=

# --- Option B / critical path: owner API Bearer JWT ---
# Required for: create trip, mock enrich flight, attachment presign/upload, export JSON.
# Also seeds share smoke when E2E_SHARE_TOKEN is absent.
# Must NOT be DPoP-bound (API mode "auto" rejects bare Bearer for bound tokens).
# Prefer a short-lived dogfood token; never commit real tokens.
E2E_OWNER_ACCESS_TOKEN=

# When true, fail if S3 PUT + confirm does not complete (default: soft-skip after presign).
# E2E_REQUIRE_ATTACHMENT_UPLOAD=false
